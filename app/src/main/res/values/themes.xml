<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.TaskReminder" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <!-- Full-screen popup: no title bar -->
    <style name="Theme.TaskReminder.Popup" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="android:windowBackground">@color/popup_background</item>
    </style>

</resources>
